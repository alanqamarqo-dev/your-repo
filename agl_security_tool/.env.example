# AGL Security Tool — Environment Configuration
# ================================================
# Copy this file to .env and modify as needed.
# All values below are defaults.

# ── Logging ──
AGL_LOG_LEVEL=INFO
AGL_LOG_FILE=              # Empty = console only. Set path for file logging.
AGL_LOG_FORMAT=text        # text | json

# ── Analysis Timeouts (seconds) ──
AGL_MYTHRIL_TIMEOUT=120
AGL_SLITHER_TIMEOUT=60
AGL_SEMGREP_TIMEOUT=30
AGL_Z3_TIMEOUT=30

# ── External Tools ──
AGL_SKIP_LLM=true
AGL_SKIP_HEIKAL=false
AGL_SKIP_MYTHRIL=false
AGL_SKIP_SLITHER=false
AGL_SKIP_SEMGREP=false

# ── PoC Generation ──
AGL_GENERATE_POC=true
AGL_RUN_FOUNDRY=false

# ── API Server ──
AGL_API_HOST=0.0.0.0
AGL_API_PORT=8000
AGL_API_WORKERS=2
AGL_API_CORS_ORIGINS=*
AGL_RATE_LIMIT=10/minute

# ── On-Chain Context (optional) ──
AGL_RPC_URL=
AGL_ETHERSCAN_KEY=

# ── MongoDB (optional, for API persistence) ──
AGL_MONGO_URI=
AGL_MONGO_DB=agl_security
